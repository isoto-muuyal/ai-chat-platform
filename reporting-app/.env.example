PORT=3001
LOG_LEVEL=info
NODE_ENV=development
COOKIE_SECURE=false
DB_URL=postgresql://user:password@localhost:5432/dbname
ADMIN_USER=admin
ADMIN_PASS=changeme
SESSION_SECRET=change-this-secret-in-production-min-32-characters-long
MESSAGE_ENCRYPTION_KEY=change-this-to-a-long-random-string
MAILERSEND_API_KEY=your-mailersend-key
MAIL_FROM=info@muuyal.tech
CONTACT_NOTIFY_EMAIL=info@muuyal.tech
APP_BASE_URL=https://npc-reporting.muuyal.tech
CHAT_API_URL=https://npc-api.muuyal.tech
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
# Optional: only needed if you enable Google/social login via Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: fallback PayPal credentials. Once the app boots, configure these
# from /admin/paypal instead — the DB-stored values take priority over these.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRO_PLAN_ID=
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
